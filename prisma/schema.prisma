// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      Int            @id @default(autoincrement())
  email                   String         @unique
  password                String
  name                    String
  role                    UserRole       @default(Student)
  profileImg              Json?          @default("{\"url\": \"\",\"publicId\":\"\"}")
  emailVerified           Boolean        @default(false)
  verificationToken       String?
  verificationTokenExpiry DateTime?
  lastVerificationSentAt  DateTime?
  stripeAccountId         String?        @default("")
  isStripeConnected       Boolean        @default(false)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  courses                 Course[]
  enrollments             Enrollment[]
  reviews                 Review[]
  notifications           Notification[]
}

enum UserRole {
  Admin
  Instructor
  Student
}

model Course {
  id               Int            @id @default(autoincrement())
  title            String
  description      String
  poster           Json?          @default("{\"url\": \"\",\"publicId\":\"\"}")
  category         CourseCategory
  price            Float
  status           CourseStatus   @default(Draft)
  rating           Float?         @default(0)
  whatYouWillLearn String[]
  requirements     String[]
  totalDuration    Int?           @default(0)
  totalVideos      Int?           @default(0)
  instructor       User           @relation(fields: [instructorId], references: [id])
  instructorId     Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  enrollments      Enrollment[]
  reviews          Review[]
  chapters         Chapter[]
}

enum CourseStatus {
  Draft
  Published
  Archived
}

enum CourseCategory {
  Programming
  Design
  Business
  Marketing
  Health
  Productivity
  Languages
  Mathematics
  Science
  Engineering
  Electronics
  Cooking
  Music
  Writing
  History
  Law
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  Int
  checkoutId String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        Int              @id @default(autoincrement())
  user      User             @relation(fields: [userId], references: [id])
  userId    Int
  type      NotificationType
  content   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

enum NotificationType {
  NewCourse
  NewReview
  NewEnrollment
}

model Chapter {
  id            Int      @id @default(autoincrement())
  title         String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId      Int
  order         Int
  isFreePreview Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  videos        Video[]
}

model Video {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  chapter     Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  chapterId   Int
  url         String
  provider    VideoProvider @default(Cloudinary)
  publicId    String?       @default("external_url")
  duration    Int
  order       Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum VideoProvider {
  Cloudinary
  Youtube
}
